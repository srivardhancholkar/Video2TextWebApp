# ===== WHISPER MODEL CONFIGURATION =====
# Select the model size for speech-to-text transcription
#
# Options:
#   tiny:   140MB   - Fastest (2-3 sec)   - Good for testing
#   base:   1.4GB   - Balanced (8-12 sec) - RECOMMENDED
#   small:  2.7GB   - Better (15-20 sec)  - Good accuracy
#   medium: 5.1GB   - Excellent (30-40 sec)
#   large:  2.9GB   - Best (60+ sec)      - Highest accuracy
#
# First run will download the model (~140MB to 2.9GB depending on size)
# Subsequent runs reuse the cached model
WHISPER_MODEL_SIZE=large

# ===== SERVER CONFIGURATION =====
# Port to run the web server on
PORT=3000

# Environment mode
NODE_ENV=development

# ===== NOTES =====
# - No API keys required! Everything runs locally
# - First transcription takes 5-15 min (model download)
# - Subsequent transcriptions take 15-20 seconds
# - For faster testing, use WHISPER_MODEL_SIZE=tiny
# - For best accuracy, use WHISPER_MODEL_SIZE=small or larger
